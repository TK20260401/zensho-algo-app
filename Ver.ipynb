    "SUM = 0\n",
    "for i in range(1, 21):\n",
    "    amari = i % 2  # MODの代わりに % を使います\n",
    "    \n",
    "    if amari == 0:\n",
    "        SUM = SUM + i\n",
    "    print(i, amari, SUM)\n",
    "\n",
    "print(SUM)"
